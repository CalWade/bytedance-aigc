# ===========================================================
# 本地开发环境变量模板
# 用法：cp .env.example .env，按需修改
# .env 已在 .gitignore，不会进 git
# ===========================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bytedance_aigc
POSTGRES_PORT=5432
# 应用层连接串（apps/api 后续 Phase 1 会用）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bytedance_aigc

# ---------- Redis ----------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ---------- 端口冲突说明 ----------
# 如果宿主机已经在跑 PostgreSQL（如 brew services start postgresql）
# 或本机已有 Redis（如 brew services start redis），改这两个变量到空闲端口：
#   POSTGRES_PORT=5433
#   REDIS_PORT=6380
# 同时记得更新 DATABASE_URL / REDIS_URL 里的 host:port

# ---------- JWT 鉴权（Phase 1.4） ----------
# 生产环境必须替换为强随机串（>= 32 字符）
# 缺失会导致 apps/api 启动直接抛错（fail-loudly，无默认值兜底）
JWT_SECRET=dev-secret-change-me-please-at-least-32-chars
JWT_EXPIRES_IN=7d

# ---------- LLM 客户端（Phase 2.2） ----------
# 用 OpenAI SDK + 自定义 baseURL 的薄 adapter 接入,不绑死厂商。
# 缺失任一项 apps/api 启动直接抛(getOrThrow,fail-loudly)。
#
# 常见填法(任选一种,改三项即可换厂商):
#   1) OpenAI 官方
#      LLM_BASE_URL=https://api.openai.com/v1
#      LLM_API_KEY=sk-...
#      LLM_MODEL=gpt-4o-mini
#   2) 火山方舟 ARK(豆包等)
#      LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
#      LLM_API_KEY=<ARK API Key>
#      LLM_MODEL=<endpoint id, 形如 ep-2026...>
#   3) DeepSeek
#      LLM_BASE_URL=https://api.deepseek.com/v1
#      LLM_API_KEY=sk-...
#      LLM_MODEL=deepseek-chat
#   4) 自建网关 / 兼容 OpenAI 协议的任意服务
#      LLM_BASE_URL=https://your-gateway/v1
#      LLM_API_KEY=<网关 token>
#      LLM_MODEL=<网关侧模型名>
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-replace-me
LLM_MODEL=gpt-4o-mini

# ---------- Admin 白名单(Phase 2.6) ----------
# 逗号分隔的 user.handle;命中才允许访问 /admin/* 端点。
# 空 / 缺失 → 全部拒绝(空白名单 = 拒绝所有人,fail-closed)。
ADMIN_HANDLES=admin

# ---------- 对象存储 / 图片上传(Phase 2.9) ----------
# STORAGE_DRIVER=mock 时 S3_* 变量可空(测试 / CI 用,不真上传)
# STORAGE_DRIVER=s3 时所有 S3_* 必填,缺失启动直接抛
STORAGE_DRIVER=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=bytedance-aigc-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/bytedance-aigc-dev
S3_FORCE_PATH_STYLE=true
