{
  "name": "bytedance-aigc",
  "version": "0.0.0",
  "private": true,
  "description": "AI 创作者辅助生产与分发平台 — 字节头条 AI 前端训练营项目",
  "license": "MIT",
  "author": "CalvinWade",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "pnpm --filter @bytedance-aigc/shared build && pnpm -r --parallel --filter=!@bytedance-aigc/shared build",
    "dev": "pnpm build:deps && pnpm -r --parallel --stream run _dev",
    "build:deps": "pnpm --filter @bytedance-aigc/shared build",
    "lint": "pnpm -r --parallel lint",
    "test": "pnpm -r --parallel test",
    "typecheck": "pnpm build:deps && pnpm -r --parallel typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:logs": "docker compose logs -f",
    "prisma:generate": "pnpm --filter @bytedance-aigc/api exec prisma generate",
    "prisma:migrate": "pnpm --filter @bytedance-aigc/api exec prisma migrate dev",
    "prisma:studio": "pnpm --filter @bytedance-aigc/api exec prisma studio",
    "prisma:seed": "pnpm --filter @bytedance-aigc/api exec prisma db seed",
    "prepare": "husky"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@playwright/test": "1.60.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "prettier": "^3.8.3"
  }
}
