// bytedance-aigc · apps/api · Prisma schema
// Phase 1.1 初始数据建模:User / Draft / DraftVersion
// Phase 1.2 追加 Prompt 库:owner 区分平台 / 私人,9 个 AI 工具枚举锁 DB 层
// 演化路线见 docs/architecture.md §4.1

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DraftMode {
  FAST
  FINE
}

enum PromptOwner {
  PLATFORM
  PRIVATE
}

enum DraftStatus {
  DRAFT
  PUBLISHED
  OFFLINE
}

enum ReviewStage {
  PREFLIGHT
  PROMPT_INPUT
  SECTION_INLINE
  POST_PUBLISH
}

enum ReviewRecommendation {
  ALLOW
  WARN
  BLOCK
}

enum DraftToolType {
  REWRITE_FLUENT
  EXPAND
  TRANSFORM_STYLE
  HEADLINE_SUB
  HEADLINE_NEW
  REWRITE_OPENING
  ADD_FACTS
  ADD_TOPIC
  IMAGE_SUGGEST
  SAFETY_REVIEW
  QUALITY_REVIEW
  PROMPT_REVIEW
  SECTION_REVIEW
  POST_PUBLISH_REVIEW
  SAFE_REWRITE
}

enum ReportCategory {
  POLITICS
  PORNOGRAPHY
  GAMBLING
  DRUGS
  VULGARITY
  FRAUD
  MEDICAL
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
}

enum ReportResolution {
  OFFLINE
  WARN
  DISMISS
}

model User {
  id        String   @id @default(cuid())
  handle    String   @unique
  createdAt DateTime @default(now())

  drafts  Draft[]
  prompts Prompt[] @relation("UserPrompts")
  reports Report[] @relation("UserReports")
  assets  Asset[]

  @@map("users")
}

model Asset {
  id        String   @id @default(cuid())
  userId    String
  key       String   @unique
  url       String
  mime      String
  size      Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("assets")
}

model Draft {
  id            String      @id @default(cuid())
  authorId      String
  mode          DraftMode   @default(FAST)
  status        DraftStatus @default(DRAFT)
  title         String
  body          Json
  version       Int         @default(1)
  publishedAt   DateTime?
  lastReviewId  String?
  offlineReason String?     @db.Text
  offlineAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  author     User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  versions   DraftVersion[]
  lastReview Review?        @relation("DraftLastReview", fields: [lastReviewId], references: [id])
  reviews    Review[]       @relation("DraftReviews")
  stat       PostStat?
  reports    Report[]

  @@index([authorId])
  @@index([status])
  @@map("drafts")
}

enum VersionKind {
  AUTO
  NAMED
  PUBLISHED
  OFFLINE_CONFLICT
}

model DraftVersion {
  id        String      @id @default(cuid())
  draftId   String
  kind      VersionKind @default(AUTO)
  snapshot  Json
  note      String?     @db.Text
  wordCount Int         @default(0)
  createdAt DateTime    @default(now())

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId])
  @@index([draftId, createdAt])
  @@map("draft_versions")
}

model Prompt {
  id             String        @id @default(cuid())
  owner          PromptOwner
  authorId       String?
  tool           DraftToolType
  name           String
  systemPrompt   String        @db.Text
  params         Json
  fewShots       Json
  designNote     String?       @db.Text
  isStarter      Boolean       @default(false)
  sourcePromptId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  author       User?    @relation("UserPrompts", fields: [authorId], references: [id], onDelete: Cascade)
  sourcePrompt Prompt?  @relation("PromptCopy", fields: [sourcePromptId], references: [id])
  copies       Prompt[] @relation("PromptCopy")

  @@index([owner, tool])
  @@index([authorId])
  @@map("prompts")
}

model Review {
  id             String               @id @default(cuid())
  draftId        String
  stage          ReviewStage
  safety         Json
  quality        Json
  recommendation ReviewRecommendation
  modelMeta      Json?
  createdAt      DateTime             @default(now())

  draft         Draft   @relation("DraftReviews", fields: [draftId], references: [id], onDelete: Cascade)
  draftLastSeen Draft[] @relation("DraftLastReview")

  @@index([draftId, createdAt(sort: Desc)])
  @@map("reviews")
}

model PostStat {
  id         String   @id @default(cuid())
  draftId    String   @unique
  impression Int      @default(0)
  click      Int      @default(0)
  dwellUnit  Int      @default(0)
  like       Int      @default(0)
  collect    Int      @default(0)
  share      Int      @default(0)
  report     Int      @default(0)
  updatedAt  DateTime @updatedAt

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@map("post_stats")
}

model Report {
  id                String                @id @default(cuid())
  postId            String
  reporterId        String
  category          ReportCategory
  reason            String?               @db.Text
  status            ReportStatus          @default(PENDING)
  resolution        ReportResolution?
  resolverId        String?
  llmRecommendation ReviewRecommendation?
  llmReason         String?               @db.Text
  createdAt         DateTime              @default(now())
  resolvedAt        DateTime?

  post     Draft @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter User  @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reporterId, postId])
  @@index([postId, status])
  @@index([status, createdAt])
  @@map("reports")
}
