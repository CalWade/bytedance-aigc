// bytedance-aigc · apps/api · Prisma schema
// Phase 1.1 初始数据建模:User / Draft / DraftVersion
// Phase 1.2 追加 Prompt 库:owner 区分平台 / 私人,9 个 AI 工具枚举锁 DB 层
// 演化路线见 docs/architecture.md §4.1

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DraftMode {
  FAST
  FINE
}

enum PromptOwner {
  PLATFORM
  PRIVATE
}

enum DraftStatus {
  DRAFT
  PUBLISHED
}

enum ReviewStage {
  PREFLIGHT
  POST_PUBLISH
}

enum ReviewRecommendation {
  ALLOW
  WARN
  BLOCK
}

enum DraftToolType {
  REWRITE_FLUENT
  EXPAND
  TRANSFORM_STYLE
  HEADLINE_SUB
  HEADLINE_NEW
  REWRITE_OPENING
  ADD_FACTS
  ADD_TOPIC
  IMAGE_SUGGEST
  SAFETY_REVIEW
  QUALITY_REVIEW
}

model User {
  id        String   @id @default(cuid())
  handle    String   @unique
  createdAt DateTime @default(now())

  drafts  Draft[]
  prompts Prompt[] @relation("UserPrompts")

  @@map("users")
}

model Draft {
  id           String      @id @default(cuid())
  authorId     String
  mode         DraftMode   @default(FAST)
  status       DraftStatus @default(DRAFT)
  title        String
  body         Json
  version      Int         @default(1)
  publishedAt  DateTime?
  lastReviewId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  author     User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  versions   DraftVersion[]
  lastReview Review?        @relation("DraftLastReview", fields: [lastReviewId], references: [id])
  reviews    Review[]       @relation("DraftReviews")
  stat       PostStat?

  @@index([authorId])
  @@index([status])
  @@map("drafts")
}

model DraftVersion {
  id        String   @id @default(cuid())
  draftId   String
  snapshot  Json
  createdAt DateTime @default(now())

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId])
  @@map("draft_versions")
}

model Prompt {
  id             String        @id @default(cuid())
  owner          PromptOwner
  authorId       String?
  tool           DraftToolType
  name           String
  systemPrompt   String        @db.Text
  params         Json
  fewShots       Json
  designNote     String?       @db.Text
  isStarter      Boolean       @default(false)
  sourcePromptId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  author       User?    @relation("UserPrompts", fields: [authorId], references: [id], onDelete: Cascade)
  sourcePrompt Prompt?  @relation("PromptCopy", fields: [sourcePromptId], references: [id])
  copies       Prompt[] @relation("PromptCopy")

  @@index([owner, tool])
  @@index([authorId])
  @@map("prompts")
}

model Review {
  id             String               @id @default(cuid())
  draftId        String
  stage          ReviewStage
  safety         Json
  quality        Json
  recommendation ReviewRecommendation
  modelMeta      Json?
  createdAt      DateTime             @default(now())

  draft         Draft   @relation("DraftReviews", fields: [draftId], references: [id], onDelete: Cascade)
  draftLastSeen Draft[] @relation("DraftLastReview")

  @@index([draftId, createdAt(sort: Desc)])
  @@map("reviews")
}

model PostStat {
  id         String   @id @default(cuid())
  draftId    String   @unique
  impression Int      @default(0)
  click      Int      @default(0)
  dwellUnit  Int      @default(0)
  like       Int      @default(0)
  collect    Int      @default(0)
  share      Int      @default(0)
  report     Int      @default(0)
  updatedAt  DateTime @updatedAt

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@map("post_stats")
}
