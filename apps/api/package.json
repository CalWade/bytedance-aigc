{
  "name": "@bytedance-aigc/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "_dev": "nest start --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "pnpm --filter @bytedance-aigc/shared build && tsc --noEmit -p tsconfig.json",
    "test": "pnpm --filter @bytedance-aigc/shared build && jest",
    "test:watch": "jest --watch",
    "test:cov": "pnpm --filter @bytedance-aigc/shared build && jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "pnpm --filter @bytedance-aigc/shared build && jest --config ./test/jest-e2e.json",
    "eval:safety": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/eval-safety.ts"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@alicloud/green20220302": "3.3.0",
    "@alicloud/openapi-client": "0.4.15",
    "@alicloud/tea-util": "1.4.11",
    "@aws-sdk/client-s3": "3.1063.0",
    "@bytedance-aigc/shared": "workspace:*",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/client": "^5.22.0",
    "@volcengine/openapi": "1.36.2",
    "bcryptjs": "3.0.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "ioredis": "5.11.1",
    "joi": "18.2.1",
    "js-yaml": "^4.1.1",
    "multer": "2.1.1",
    "openai": "6.41.0",
    "p-limit": "3.1.0",
    "reflect-metadata": "^0.2.2",
    "resend": "6.12.4",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcryptjs": "3.0.0",
    "@types/express": "^5.0.0",
    "@types/ioredis": "5.0.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/ms": "^2.1.0",
    "@types/multer": "2.1.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "p-limit": "3.1.0",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/scripts"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s",
      "scripts/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
